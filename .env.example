# Options Trader — Secrets Template
# Copy this to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env
#
# Run the setup wizard to fill these automatically:
#   python main.py --setup
#
# ⚠️  NEVER commit .env to version control.

# Robinhood credentials
ROBINHOOD_USERNAME="your.email@example.com"
ROBINHOOD_PASSWORD="your_robinhood_password"

# Robinhood TOTP seed (from Robinhood app → Security → 2FA → Authenticator App)
# Looks like: JBSWY3DPEHPK3PXP
ROBINHOOD_TOTP_SEED="your_base32_totp_seed"

# Resend (https://resend.com/api-keys — create a "Sending access" key)
# Sender must be on a domain verified at https://resend.com/domains
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Display Name <verified.sender@yourdomain.com>"

# Finnhub (https://finnhub.io → Dashboard → API Key)
FINNHUB_API_KEY="your_finnhub_api_key"
